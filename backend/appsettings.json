{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Features": {
    "EnableAuth": true,
    "EnablePagination": true
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=enjaz;Username=enjaz_user;Password=YOUR_DB_PASSWORD_HERE;Minimum Pool Size=5;Maximum Pool Size=50;Connection Idle Lifetime=120;Timeout=15;Command Timeout=30;Application Name=enjaz-api",
    "Redis": "localhost:6379,abortConnect=false,connectTimeout=5000,syncTimeout=3000"
  },
  "Jwt": {
    "Key": "YOUR_SUPER_SECRET_JWT_KEY_HERE_MUST_BE_LONG",
    "Issuer": "EnjazApi",
    "Audience": "EnjazWeb"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Warning"
      }
    }
  },
  "AllowedHosts": "*"
}
